# ============================================
# Cristalmad — Variabili d'Ambiente
# ============================================
# Copia questo file in .env e compila i valori.
# NON committare mai il file .env nel repository!

# --- Supabase ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_YOUR_ANON_KEY_HERE

# Chiave service role — SOLO BACKEND, mai esposta al client
SUPABASE_SERVICE_ROLE_KEY=eyJ_YOUR_SERVICE_ROLE_KEY_HERE

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Chiave pubblica Stripe — può andare al frontend
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# --- App ---
APP_URL=http://localhost:5173
ADMIN_EMAIL=admin@cristalmad.com
